{
  "name": "agent-goal-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Portable Codex-compatible /goal runtime with a Pi adapter.",
  "keywords": [
    "pi-package",
    "agent-goal-runtime",
    "codex-goal",
    "slash-command"
  ],
  "bin": {
    "agent-goal": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./pi": "./dist/adapters/pi/index.js"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "schemas",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test dist/tests/*.test.js",
    "check": "npm run build && npm test"
  },
  "pi": {
    "extensions": [
      "./dist/adapters/pi/index.js"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": { "optional": true },
    "@earendil-works/pi-coding-agent": { "optional": true },
    "typebox": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
